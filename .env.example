# ─────────────────────────────────────────────────────────────────
# AI Execution Lab — Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and NEVER committed.
# ─────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────
# Production canonical URL — no trailing slash
# Used by: metadataBase, sitemap.xml, robots.txt, canonical tags,
# article JSON-LD, OG image generation, and article-share component.
NEXT_PUBLIC_SITE_URL=https://lab.asquaresolution.com

# ─────────────────────────────────────────────────────────────────
# AI Content Distribution + Scam Intelligence engines
# Without these, the engines run in MOCK mode (memory store, fake AI).
# Set all of them to go LIVE in production.
# ─────────────────────────────────────────────────────────────────

# ── AI (Vertex AI Gemini) — required for live generation ──────────
# Vertex project + region. VERTEX_PROJECT_ID falls back to FIREBASE_PROJECT_ID.
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
# Auth — use ONE of these:
#   service account JSON (raw or base64). Needs IAM role roles/aiplatform.user.
GOOGLE_SERVICE_ACCOUNT_JSON=
#   OR a pre-minted OAuth token (e.g. Workload Identity):
# VERTEX_ACCESS_TOKEN=
# Optional model + cost overrides (sensible defaults applied):
# VERTEX_FLASH_MODEL=gemini-2.5-flash
# VERTEX_PRO_MODEL=gemini-2.5-pro
# VERTEX_EMBED_MODEL=text-multilingual-embedding-002
# DEEP_TIER=pro                 # set 'flash' for low-cost article generation
# VERTEX_TOKENS_PER_MIN=100000  # quota monitor threshold
# Autonomous + throttle tuning:
# AUTOPILOT_PER_RUN=3
# BUNDLES_PER_DAY=20
# PUBLISH_PER_HOUR=12
# AUTOPILOT_REGION=India

# ── Firestore — required for live persistence ─────────────────────
FIREBASE_PROJECT_ID=
# Use ONE of the following for auth:
FIREBASE_API_KEY=
# FIREBASE_ACCESS_TOKEN=        # service-account bearer token (preferred server-side)
# FIREBASE_DATABASE_ID=(default)

# ── Security — required in production ─────────────────────────────
# Gates all admin API routes (/api/distribution/*, /api/scam-intel/moderate, dashboards data).
ADMIN_API_TOKEN=
# Authenticates Vercel cron invocations (drain-queue, update-trending, clean-cache).
CRON_SECRET=

# ── Ops (optional) ────────────────────────────────────────────────
# LOG_LEVEL=info                 # debug | info | warn | error
# STORE_FILE=./.data/store.json  # dev only: persist memory store to disk (ignored when Firestore set)

# ── Future channel integrations (optional, stubs until set) ───────
# WORDPRESS_API_URL=
# WORDPRESS_USER=
# WORDPRESS_APP_PASSWORD=
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_AUTHOR_URN=
# TWITTER_BEARER_TOKEN=

# ── AdSense (optional — ads render only when set; auto-hidden for paid) ──
# Your AdSense publisher id, e.g. ca-pub-3102382127523426
NEXT_PUBLIC_ADSENSE_CLIENT=
# Ad unit slot ids from the AdSense dashboard:
NEXT_PUBLIC_ADSENSE_SLOT_BELOW_VERDICT=
NEXT_PUBLIC_ADSENSE_SLOT_IN_CONTENT=
# Shared paid-plan flag key (cookie / localStorage) set by ScamCheck/TrustSeal:
# NEXT_PUBLIC_PAID_FLAG_KEY=sc_plan

# ── Analytics (optional — platform works without these) ───────────
# Plausible Analytics: set to your domain (e.g. lab.asquaresolution.com)
# Script is loaded from https://plausible.io/js/plausible.js
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=lab.asquaresolution.com

# Google Analytics 4: set to your measurement ID
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────────────────────────
# Vercel Dashboard Environment Variables
# Set these in: Vercel → Project → Settings → Environment Variables
# Do NOT add them to any committed file.
#
# Required for production:
#   NEXT_PUBLIC_SITE_URL        = https://lab.asquaresolution.com
#   VERTEX_PROJECT_ID           = <gcp project>
#   GOOGLE_SERVICE_ACCOUNT_JSON = <sa json>  (or VERTEX_ACCESS_TOKEN)
#   FIREBASE_PROJECT_ID         = <project id>
#   FIREBASE_API_KEY            = <web api key>   (or FIREBASE_ACCESS_TOKEN)
#   ADMIN_API_TOKEN             = <long random secret>
#   CRON_SECRET                 = <long random secret>
#
# Optional analytics:
#   NEXT_PUBLIC_PLAUSIBLE_DOMAIN = lab.asquaresolution.com
#   NEXT_PUBLIC_GA_ID = G-XXXXXXXXXX
# ─────────────────────────────────────────────────────────────────
